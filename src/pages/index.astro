---
import '../styles/global.css';
import profilePhoto from '../assets/profile-photo.jpg';

const researchItems = [
  {
    title: 'RAG 增强智能教育系统研究',
    date: '2025.10 - 2026.01',
    bullets: [
      '围绕教育知识库构建、个性化问答、沉浸式课堂与学习分析开展研究。',
      '参与轻量化智能教学框架设计与系统实现，负责交互流程、沉浸式教学模块与前端功能落地。',
      '相关成果发表于 The Web Conference 2026 Demo Track。',
    ],
  },
  {
    title: '智能体记忆与题目自动评估研究',
    date: '2025 - 至今',
    bullets: [
      '梳理检索式记忆、参数化记忆、工作流记忆等智能体长期记忆建模方法。',
      '基于 Bloom 教育目标分类设计题目自动化评估框架，覆盖认知层级、认知一致性与题目可解性分析。',
      '已完成文献调研与初步方案设计，处于实验验证阶段。',
    ],
  },
];

const projects = [
  {
    name: '灵知寓学 / RISE',
    type: 'Intelligent Education',
    link: 'https://github.com/FrancesscaWY',
    body:
      '基于 LLM、RAG、MCP 与数字人技术的智能教育系统，支持教育知识问答、课堂互动与教学辅助。本人负责数字人交互设计、MCP 教学流程、系统原型、前端开发与 LLM 接口联调。',
    result: '中国大学生计算机设计大赛国家级二等奖；WWW 2026 Demo Track 论文。',
    tags: ['RAG', 'MCP', 'LLM', 'Digital Human'],
  },
  {
    name: 'VirTour',
    type: 'Agent-guided Tourism',
    link: 'https://github.com/FrancesscaWY/VirtualTour-Back',
    body:
      '智能体驱动的沉浸式虚拟旅游系统，融合景点问答、语音交互、数字人导览与全景漫游。本人负责 TTS 流式链路、MCP 控制流程、数字人接入与前端核心开发。',
    result: '第 19 届“挑战杯”国家级特等奖。',
    tags: ['Python', 'RAG', 'TTS', 'MCP'],
  },
  {
    name: '多模态情绪识别社交辅助系统',
    type: 'Multimodal AI',
    link: 'https://github.com/FrancesscaWY/Emotions-Attention-Identify',
    body:
      '面向自闭症儿童情绪识别与社交辅助场景，构建融合面部、语音、文本信息的辅助系统；公开识别模块基于 FastAPI、OpenCV、DeepFace 与 Mediapipe。',
    result: '软件著作权 1 项。',
    tags: ['FastAPI', 'OpenCV', 'DeepFace', 'Mediapipe'],
  },
  {
    name: 'IntelliHealthCare',
    type: 'Smart Eldercare',
    link: 'https://github.com/FrancesscaWY/IntelliHealthCare',
    body:
      '面向长者、家属与机构运营团队的智慧康养平台，覆盖健康档案、健康监测、服务预约、内容社区、RAG 与多智能体能力。',
    result: 'Monorepo 包含用户端、后台端、NestJS 后端与项目文档。',
    tags: ['Vue 3', 'NestJS', 'Prisma', 'Agent'],
  },
  {
    name: 'SketchMind',
    type: 'AI Feedback Prototype',
    link: 'https://github.com/FrancesscaWY/SketchMind',
    body:
      '草图学习反馈原型，支持绘图任务校验、作品分析与 AI 反馈。项目使用 Next.js、Excalidraw、Express 与 Gemini 构建。',
    result: '关注 AI 反馈在学习过程中的嵌入式支持。',
    tags: ['Next.js', 'Excalidraw', 'Express', 'Gemini'],
  },
  {
    name: '在线作业管理系统',
    type: 'Full-stack Practice',
    link: 'https://github.com/FrancesscaWY/Student-Homework-Submit-Front',
    body:
      '面向班级作业收取的 Web 应用，支持管理员发布、编辑、收取作业，学生登录、查看与提交作业。本人独立完成前后端开发、部署及运维。',
    result: '公开仓库包含前端与后端两个部分。',
    tags: ['Vue', 'TypeScript', 'Node.js', 'Deployment'],
  },
];

const honors = [
  '软件著作权 1 项（2026）',
  '第 19 届“挑战杯”全国大学生课外学术科技作品竞赛国家级特等奖（2025）',
  '中国大学生计算机设计大赛国家级二等奖（2025）',
  '国家励志奖学金、筑梦奖学金、三好学生（2025）',
  '中国大学生计算机设计大赛重庆市三等奖（2024）',
  '二等奖学金、三好学生、砥砺奋斗奖（2024）',
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="魏艳（Yan Wei）个人主页：西南大学软件工程本科生，研究方向包括智能教育、可信 AI、RAG/Agent 系统与应用型软件开发。"
    />
    <meta name="theme-color" content="#f7f7f5" />
    <meta property="og:title" content="魏艳 / Yan Wei" />
    <meta
      property="og:description"
      content="西南大学软件工程本科生，关注智能教育、可信 AI、RAG/Agent 系统与应用型软件开发。"
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://francesscawy.github.io/" />
    <title>魏艳 / Yan Wei</title>
  </head>
  <body>
    <div class="page">
      <header class="topbar">
        <a class="brand" href="#top" aria-label="返回首页">
          <strong>魏艳</strong>
          <span>Yan Wei</span>
        </a>
        <nav class="nav" aria-label="页面导航">
          <a href="#education">Education</a>
          <a href="#research">Research</a>
          <a href="#publication">Publication</a>
          <a href="#projects">Projects</a>
          <a href="#honors">Honors</a>
        </nav>
      </header>

      <main id="top">
        <section class="profile" aria-labelledby="profile-title">
          <div class="profile-copy">
            <div class="name-line">
              <h1 id="profile-title">魏艳</h1>
              <p class="english-name">Yan Wei</p>
            </div>
            <p class="title-line">本科生，软件工程，西南大学（211）</p>
            <p class="summary">
              研究兴趣包括智能教育、可信 AI、RAG 增强生成、Agent/MCP 工作流与应用型软件系统。当前工作主要围绕教育场景中的知识库问答、沉浸式交互、学习评价与大模型系统工程化展开。
            </p>
            <div class="contact-list" aria-label="联系信息">
              <span>Email: <a href="mailto:weiyan_francessca@163.com">weiyan_francessca@163.com</a></span>
              <span>GitHub: <a href="https://github.com/FrancesscaWY" target="_blank" rel="noreferrer">FrancesscaWY</a></span>
            </div>
          </div>
          <img class="profile-photo" src={profilePhoto.src} alt="魏艳证件照" width="156" height="187" />
        </section>

        <div class="content">
          <aside class="sidebar" aria-label="个人摘要">
            <section class="info-box">
              <h2>Profile</h2>
              <dl class="info-list">
                <div>
                  <dt>Status</dt>
                  <dd>Software Engineering Undergraduate</dd>
                </div>
                <div>
                  <dt>Institution</dt>
                  <dd>Southwest University</dd>
                </div>
                <div>
                  <dt>Period</dt>
                  <dd>2023.09 - Present</dd>
                </div>
              </dl>
            </section>
            <section class="info-box">
              <h2>Keywords</h2>
              <dl class="info-list">
                <div>
                  <dt>Research</dt>
                  <dd>Intelligent Education, Trustworthy AI, LLM Evaluation</dd>
                </div>
                <div>
                  <dt>Systems</dt>
                  <dd>RAG, Agent Workflow, MCP, Multimodal AI</dd>
                </div>
                <div>
                  <dt>Engineering</dt>
                  <dd>Python, TypeScript, Vue, Node.js, Docker, Git</dd>
                </div>
              </dl>
            </section>
          </aside>

          <div class="main-column">
            <section class="section" id="education" aria-labelledby="education-title">
              <div class="section-header">
                <h2 id="education-title">Education</h2>
                <span class="section-kicker">教育背景</span>
              </div>
              <article class="entry">
                <div class="entry-header">
                  <h3>西南大学，软件工程，本科</h3>
                  <span class="entry-meta">2023.09 - 至今</span>
                </div>
                <ul>
                  <li>综合排名：8/117；成绩排名：12/117；GPA：3.61/5.00。</li>
                  <li>英语能力：CET-4 494，CET-6 446。</li>
                  <li>主修课程：汇编语言与计算机组成结构、类库与数据结构、计算机网络、操作系统原理、数据库原理及应用、离散数学、线性代数。</li>
                </ul>
              </article>
            </section>

            <section class="section" id="research" aria-labelledby="research-title">
              <div class="section-header">
                <h2 id="research-title">Research Experience</h2>
                <span class="section-kicker">科研经历</span>
              </div>
              <div class="entry-list">
                {researchItems.map((item) => (
                  <article class="entry">
                    <div class="entry-header">
                      <h3>{item.title}</h3>
                      <span class="entry-meta">{item.date}</span>
                    </div>
                    <ul>
                      {item.bullets.map((bullet) => <li>{bullet}</li>)}
                    </ul>
                  </article>
                ))}
              </div>
            </section>

            <section class="section" id="publication" aria-labelledby="publication-title">
              <div class="section-header">
                <h2 id="publication-title">Publication</h2>
                <span class="section-kicker">学术成果</span>
              </div>
              <article class="publication">
                <p class="publication-title">RISE: A Retrieval-Augmented Generation Enhanced Immersive System for Education.</p>
                <p>
                  Guo Chen, Haowei Tang, <strong>Yan Wei</strong>, Yuming Wang, Haoyang Zhang, Yikang Hou, Maolin Zheng, Junjie Huang. <em>The Web Conference 2026 Demo Track</em>, 2026.
                </p>
              </article>
            </section>

            <section class="section" id="projects" aria-labelledby="projects-title">
              <div class="section-header">
                <h2 id="projects-title">Selected Projects</h2>
                <span class="section-kicker">项目经历</span>
              </div>
              <div class="project-grid">
                {projects.map((project) => (
                  <article class="project-card">
                    <p class="project-type">{project.type}</p>
                    <h3>
                      <a href={project.link} target="_blank" rel="noreferrer">{project.name}</a>
                    </h3>
                    <p>{project.body}</p>
                    <p><strong>成果：</strong>{project.result}</p>
                    <div class="tags" aria-label={`${project.name} 技术标签`}>
                      {project.tags.map((tag) => <span>{tag}</span>)}
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <section class="section" id="honors" aria-labelledby="honors-title">
              <div class="section-header">
                <h2 id="honors-title">Honors</h2>
                <span class="section-kicker">奖项荣誉</span>
              </div>
              <ul class="plain-list">
                {honors.map((honor) => <li>{honor}</li>)}
              </ul>
            </section>
          </div>
        </div>
      </main>

      <footer class="footer">
        <span>© 2026 Yan Wei</span>
        <a href="#top">Back to top</a>
      </footer>
    </div>
  </body>
</html>
